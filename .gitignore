# ── OS artefacts ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Python ──
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# ── env files (never commit credentials) ──
.env
.env.*

# ── Jupyter ──
.ipynb_checkpoints/

# ── hidden tool/config directories at the repo root — keep only .github ──
/.*/
!/.github/

# ── LaTeX build artefacts (the manuscript recompiles from source) ──
manuscript/main.aux
manuscript/main.log
manuscript/main.bbl
manuscript/main.blg
manuscript/main.out
manuscript/main.xdv
manuscript/main.fls
manuscript/main.fdb_latexmk
manuscript/*.synctex.gz

# ── run artefacts & checkpoints (regenerated by the pipeline) ──
/*.log
nohup.out
data/econ/_*ckpt/
data/**/_bootstrap_ckpt/
data/**/_robust_ckpt/
data/analysis/
data/econ/_legacy/

# ── editor/backup droppings ──
*~
*.bak
*.orig
*.swp

# ── data policy: raw and most normalized inputs travel in the GitHub Release
#    asset (Path B bundle), not in git. The two committed spot placebo
#    parquets are the only normalized files kept in-repo (robustness Test A
#    reads them directly). ──
data/raw/
data/normalized/cex/
data/normalized/benchmarks/
data/normalized/spot/*
!data/normalized/spot/xrp_ccdata_1h.parquet
!data/normalized/spot/doge_ccdata_1h.parquet
